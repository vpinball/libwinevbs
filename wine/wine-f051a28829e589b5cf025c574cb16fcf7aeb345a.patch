+        return E_NOTIMPL;
+    else if (!vbs_wcsicmp(interval, L"d"))
+        return E_NOTIMPL;
+    else if (!vbs_wcsicmp(interval, L"w"))
+        return E_NOTIMPL;
+    else if (!vbs_wcsicmp(interval, L"ww"))
+        return E_NOTIMPL;
+    else if (!vbs_wcsicmp(interval, L"h")) {
